{
  "name": "ianrios.github.io",
  "version": "0.2.0",
  "private": true,
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^6.0.2",
    "three": "^0.184.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && brickwall --full && tsx scripts/validate.ts && knip --no-config-hints",
    "format": "prettier . --write",
    "check": "npm run format && npm run typecheck && npm run lint",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "deploy": "npm run check && npm test && npm run build && firebase deploy",
    "optimize-images": "tsx scripts/optimize-images.ts"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianrios/brickwall": "file:vendor/ianrios-brickwall-0.0.0.tgz",
    "@ianrios/drift": "file:vendor/ianrios-drift-0.0.0.tgz",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.6.0",
    "jsdom": "^27.0.1",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "sass": "^1.97.2",
    "sharp": "^0.35.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
